pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/<your-username>/<repo>.git'
            }
        }
        stage('Build') {
            steps {
                sh 'echo "Build step running"'
            }
        }
        stage('Test') {
            steps {
                sh 'python3 calculator.py'
            }
        }
        stage('Deploy') {
            steps {
                sh 'echo "Deploy step"'
            }
        }
    }
}
